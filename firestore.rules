rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Public profile read (for /u/username page)
      allow read: if resource.data.username != null;

      // Courses subcollection — private to owner
      match /courses/{courseId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Videos subcollection
        match /videos/{videoId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Progress — private to owner
      match /progress/{videoId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Certificates — private to owner
      match /certificates/{courseId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Global video AI content (quizzes, flashcards, notes)
    // Readable by any authenticated user; only writable by server (Admin SDK)
    match /videos/{videoId} {
      match /quizzes/{quizId} {
        allow read: if request.auth != null;
        allow write: if false; // server-only via Admin SDK
      }
      match /flashcards/{flashcardId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
      match /notes/{noteId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == resource.data.userId;
      }
    }
  }
}
